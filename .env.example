# Storage adapter — "memory" runs entirely in-process with seeded fixtures
# (no external services). Use "supabase" once you have a Supabase project.
STORAGE_ADAPTER=memory

# Authentication adapter — "stub" auto-signs the visitor in as a demo user
# when they hit /login. Use "supabase" with the keys below in production.
AUTH_ADAPTER=stub

# Email adapter — "console" prints emails to stdout instead of sending.
# Use "resend" with RESEND_API_KEY in production.
EMAIL_ADAPTER=console

# Public site URL — used in OG cards, email links, OAuth redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Supabase (only when STORAGE_ADAPTER=supabase or AUTH_ADAPTER=supabase) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Cron protection (set in production) ===
CRON_SECRET=

# === Resend (only when EMAIL_ADAPTER=resend) ===
RESEND_API_KEY=
RESEND_FROM=DevFeed <digest@devfeed.example>

# === Unsubscribe link signing ===
UNSUBSCRIBE_SECRET=
